<UserControl
    x:Class="AP.Plugin.DeviceConfiguration.Views.ScannerSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:prism="http://prismlibrary.com/">

    <Expander
        Background="{DynamicResource MaterialDesignCardBackground}"
        Header="基恩士扫码枪 (串口) 配置"
        IsExpanded="False">
        <StackPanel Margin="16">

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    Text="通信串口 :" />
                <TextBox
                    Grid.Column="1"
                    md:HintAssist.Hint="例如: COM1"
                    Text="{Binding PortName, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    Text="波特率 :" />
                <ComboBox Grid.Column="1" Text="{Binding BaudRate}">
                    <ComboBoxItem Content="9600" />
                    <ComboBoxItem Content="19200" />
                    <ComboBoxItem Content="38400" />
                    <ComboBoxItem Content="115200" />
                </ComboBox>
            </Grid>

            <Button
                HorizontalAlignment="Right"
                Command="{Binding ApplySettingsCommand}"
                Content="保存配置"
                Style="{StaticResource MaterialDesignPaperButton}" />
        </StackPanel>
    </Expander>
</UserControl>
